{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2022",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "types": [
      "node",
      "jest"
    ],
    "paths": {
      "@cap/cap-nest": [
        "./libs/cap-nest/dist"
      ],
      "@cap/cap-nest/*": [
        "./libs/cap-nest/dist/*"
      ],
      "@cap/mikroorm-storage": [
        "./libs/storage-mikro-orm/dist"
      ],
      "@cap/mikroorm-storage/*": [
        "./libs/storage-mikro-orm/dist/*"
      ],
      "@cap/azure-servicebus-transport": [
        "./libs/transport-azure-servicebus/dist"
      ],
      "@cap/azure-servicebus-transport/*": [
        "./libs/transport-azure-servicebus/dist/*"
      ],
      "@cap/nestjs-microservices-transport": [
        "./libs/transport-nestjs-microservices/dist"
      ],
      "@cap/nestjs-microservices-transport/*": [
        "./libs/transport-nestjs-microservices/dist/*"
      ],
      "@cap/cap-dashboard": [
        "./libs/cap-dashboard/dist"
      ],
      "@cap/cap-dashboard/*": [
        "./libs/cap-dashboard/dist/*"
      ]
    }
  },
  "include": [
    "apps/**/*",
    "libs/**/*.spec.ts",
    "types/**/*.d.ts"
  ]
}
