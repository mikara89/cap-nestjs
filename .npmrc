; ---------- Basic registry setup ----------
@cap:registry=http://localhost:4873/

; Tell npm to **always** send auth for your registry
always-auth=true
; Send username and password for your registry
http://localhost:4873/_auth=dGVzdDE6dGVzdDE=

; Turn off strict TLS checks because we’re on plain HTTP
; (remove this once you put Verdaccio behind HTTPS)
strict-ssl=false


; ---------- Auth token ----------
; After you run `npm adduser --registry http://localhost:4873`
; npm will append something like the line below automatically.
; Keep it here so CI / Docker builds can do `npm ci` without a prompt.
; //localhost:4873/:_authToken=YOUR_TOKEN_HERE


; ---------- Scoped packages (optional) ----------
; If you only want company-scoped packages going through Verdaccio
; and everything else through the public registry, comment out the
; global `registry=` above and use a scoped rule instead:
; @your-scope:registry=http://localhost:4873/


; ---------- Corporate proxy (optional) ----------
; If you sit behind an HTTP proxy and npm commands hang,
; uncomment and fill these in (Verdaccio works fine through a proxy).
; proxy=http://proxy.yourcorp.tld:8080/
; https-proxy=http://proxy.yourcorp.tld:8080/


; ---------- Performance niceties ----------
; Save disk space by skipping the package-lock for libraries
; and turning off the npm update notifier in CI images.
; package-lock=false
; update-notifier=false
